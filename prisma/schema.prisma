// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Application {
  id                                 String                 @id @default(uuid())
  nuid                               String                 @unique
  fullName                           String
  preferredFullName                  String
  phoneticPronunciation              String
  pronunciationAudioUrl              String
  pronouns                           String
  email                              String
  phoneNumber                        String
  college                            String
  major                              String
  minors                             String
  year                               Int
  semester                           String
  constituency                       String
  communityConstituencyId            String?
  communityConstituency              CommunityConstituency? @relation(fields: [communityConstituencyId], references: [id])
  whySenateLongAnswer                String
  constituencyIssueLongAnswer        String
  diversityEquityInclusionLongAnswer String
  conflictSituationLongAnswer        String
  campaignBlurb                      String                 @default("")
  nominationFormPdfUrl               String?
  createdAt                          DateTime               @default(now())

  @@map("applications")
}

enum NominationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Nomination {
  id                      String                 @id @default(uuid())
  nominee                 String
  fullName                String
  email                   String
  college                 String
  major                   String
  status                  NominationStatus       @default(PENDING)
  constituencyType        String?                // 'academic' or 'community'
  communityConstituencyId String?
  communityConstituency   CommunityConstituency? @relation(fields: [communityConstituencyId], references: [id])
  createdAt               DateTime               @default(now())

  @@map("nominations")
}

model Endorsement {
  id                  String   @id @default(uuid())
  endorserName        String
  endorserEmail       String
  applicantName       String
  definingTraits      String
  leadershipQualities String
  areasForDevelopment String
  createdAt           DateTime @default(now())

  @@map("endorsements")
}

model CommunityConstituency {
  id           String        @id @default(uuid())
  name         String        @unique
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
  nominations  Nomination[]

  @@map("community_constituencies")
}
