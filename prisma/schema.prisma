// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Application {
  id                    String   @id @default(uuid())
  nuid                  String   @unique
  fullName              String
  preferredFullName     String
  nickname              String
  phoneticPronunciation String
  pronouns              String
  email                 String
  phoneNumber           String
  college               String
  major                 String
  minors                String
  year                  Int
  semester              String
  constituency          String
  createdAt             DateTime @default(now())

  @@map("applications")
}

enum NominationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Nomination {
  id        String           @id @default(uuid())
  nominee   String
  fullName  String
  email     String
  college   String
  major     String
  status    NominationStatus @default(PENDING)
  createdAt DateTime         @default(now())

  @@map("nominations")
}

model Endorsement {
  id                  String   @id @default(uuid())
  endorserName        String
  endorserEmail       String
  applicantName       String
  definingTraits      String
  leadershipQualities String
  areasForDevelopment String
  createdAt           DateTime @default(now())

  @@map("endorsements")
}
