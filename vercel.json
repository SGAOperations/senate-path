{
  "version": 2,
  "buildCommand": "npx nx build backend && npx nx build frontend",
  "outputDirectory": "dist/apps/frontend",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 3008,
      "maxDuration": 10
    }
  }
}